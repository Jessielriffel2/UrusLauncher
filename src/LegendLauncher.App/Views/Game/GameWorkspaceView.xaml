<UserControl x:Class="LegendLauncher.App.Views.Game.GameWorkspaceView"
             x:Name="WorkspaceRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hosting="clr-namespace:LegendLauncher.App.GameHosting"
             xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
             xmlns:loc="clr-namespace:LegendLauncher.App.Localization"
             Focusable="False">
    <UserControl.Resources>
        <Style x:Key="WorkspaceToolbarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="#B5081728" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentStrongBrush}" />
                                <Setter TargetName="Border" Property="Background" Value="#B4122838" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Opacity" Value="0.72" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LayoutButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WorkspaceToolbarButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="SessionTabBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#A50A1828" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="#C2112636" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SessionPaneBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#020811" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                    <Setter Property="BorderThickness" Value="1.5" />
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#35E5D8" BlurRadius="9" ShadowDepth="0" Opacity="0.3" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16,0,16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
            <RowDefinition Height="34" />
        </Grid.RowDefinitions>

        <Grid x:Name="CompactGameToolbar"
              Grid.Row="0"
              VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="150" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Command="{Binding ShowLauncherCommand}"
                    Style="{StaticResource WorkspaceToolbarButtonStyle}"
                    BorderBrush="{StaticResource AccentStrongBrush}"
                    Foreground="{StaticResource AccentBrush}"
                    AutomationProperties.Name="{loc:Localize Workspace_BackToLauncher}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE72B;" FontFamily="Segoe Fluent Icons" FontSize="13" Margin="0,0,8,0" />
                    <TextBlock Text="{loc:Localize Workspace_BackToLauncher}" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <ScrollViewer x:Name="SessionTabsScrollViewer"
                          Grid.Column="2"
                          VerticalAlignment="Center"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Disabled"
                          Focusable="False"
                          shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <ItemsControl ItemsSource="{Binding Workspace.Sessions}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource SessionTabBorderStyle}"
                                    MinWidth="132"
                                    MaxWidth="190"
                                    Height="34"
                                    Margin="0,0,5,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="30" />
                                    </Grid.ColumnDefinitions>
                                    <Button Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            HorizontalContentAlignment="Stretch"
                                            Padding="10,0,3,0"
                                            Cursor="Hand"
                                            Command="{Binding DataContext.Workspace.SelectSessionCommand, ElementName=WorkspaceRoot}"
                                            CommandParameter="{Binding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding TabTitle}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </Button>
                                    <Button Grid.Column="1"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="{StaticResource TextMutedBrush}"
                                            FontFamily="Segoe Fluent Icons"
                                            FontSize="10"
                                            Content="&#xE711;"
                                            Cursor="Hand"
                                            Command="{Binding DataContext.Workspace.CloseSessionCommand, ElementName=WorkspaceRoot}"
                                            CommandParameter="{Binding}"
                                            AutomationProperties.Name="{loc:Localize Session_End}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Button Grid.Column="4"
                    Content="{loc:Localize Accounts_AddLabel}"
                    Command="{Binding AddAccountCommand}"
                    Style="{StaticResource WorkspaceToolbarButtonStyle}"
                    Padding="11,0"
                    AutomationProperties.Name="{loc:Localize Accounts_Add}" />

            <StackPanel x:Name="WorkspaceActionGroup"
                        Grid.Column="6"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <ComboBox x:Name="WorkspaceLanguageSelector"
                          Width="140"
                          Margin="0,0,8,0"
                          Style="{StaticResource LanguageComboStyle}"
                          ItemsSource="{Binding Languages}"
                          SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          PreviewMouseLeftButtonDown="ComboBoxSelector_OnPreviewMouseLeftButtonDown"
                          PreviewKeyDown="ComboBoxSelector_OnPreviewKeyDown"
                          ToolTip="{loc:Localize Language_Select}"
                          AutomationProperties.Name="{loc:Localize Language_SelectAutomation}"
                          shell:WindowChrome.IsHitTestVisibleInChrome="True" />
                <Button Command="{Binding Workspace.ToggleMuteCommand}"
                        Style="{StaticResource WorkspaceToolbarButtonStyle}"
                        Margin="0,0,8,0"
                        Padding="10,0"
                        AutomationProperties.Name="{loc:Localize Audio_ToggleGlobal}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Workspace.MuteGlyph}" FontFamily="Segoe Fluent Icons"
                                   FontSize="14" Foreground="#FF6B87" Margin="0,0,7,0" />
                        <TextBlock Text="{Binding Workspace.MuteLabel}" />
                    </StackPanel>
                </Button>

                <Button Content="1"
                        Command="{Binding Workspace.SingleLayoutCommand}"
                        ToolTip="{loc:Localize Layout_OneTooltip}"
                        AutomationProperties.Name="{loc:Localize Layout_OneAutomation}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource LayoutButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Workspace.IsSingleLayout}" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                    <Setter Property="Background" Value="#C214343D" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="2"
                        Command="{Binding Workspace.SplitTwoLayoutCommand}"
                        ToolTip="{loc:Localize Layout_TwoTooltip}"
                        AutomationProperties.Name="{loc:Localize Layout_TwoAutomation}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource LayoutButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Workspace.IsSplitTwoLayout}" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                    <Setter Property="Background" Value="#C214343D" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="4"
                        Command="{Binding Workspace.GridFourLayoutCommand}"
                        Margin="0,0,8,0"
                        ToolTip="{loc:Localize Layout_FourTooltip}"
                        AutomationProperties.Name="{loc:Localize Layout_FourAutomation}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource LayoutButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Workspace.IsGridFourLayout}" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                    <Setter Property="Background" Value="#C214343D" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Command="{Binding Workspace.DetachSessionCommand}"
                        CommandParameter="{Binding Workspace.SelectedSession}"
                        IsEnabled="{Binding Workspace.CanDetachSelected}"
                        Style="{StaticResource WorkspaceToolbarButtonStyle}"
                        Padding="11,0"
                        AutomationProperties.Name="{loc:Localize Session_DetachSelected}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8A7;" FontFamily="Segoe Fluent Icons" FontSize="13" Margin="0,0,7,0" />
                        <TextBlock Text="{loc:Localize Session_DetachLabel}" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <Border x:Name="MainWindowCaptionButtonReservedSpace"
                    Grid.Column="7"
                    Width="150"
                    Background="Transparent"
                    IsHitTestVisible="False" />
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="78" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#C00A1727"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="9"
                    ClipToBounds="True">
                <Grid>
                    <Image Source="/UrusLauncher.App;component/Assets/castle-background.png"
                           Stretch="UniformToFill"
                           Opacity="0.33"
                           VerticalAlignment="Bottom"
                           Height="330"
                           IsHitTestVisible="False" />
                    <Rectangle IsHitTestVisible="False">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#F30A1727" Offset="0" />
                                <GradientStop Color="#B50A1727" Offset="0.48" />
                                <GradientStop Color="#350A1727" Offset="1" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <StackPanel Margin="10,12">
                        <Button Content="&#xE710;"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="16"
                                Command="{Binding AddAccountCommand}"
                                Style="{StaticResource WorkspaceToolbarButtonStyle}"
                                Width="46"
                                Height="40"
                                Padding="0"
                                Margin="0,0,0,12"
                                ToolTip="{loc:Localize Accounts_Add}" />
                        <ItemsControl ItemsSource="{Binding Workspace.Sessions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="52"
                                            Height="52"
                                            Margin="0,0,0,10"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding DataContext.Workspace.SelectSessionCommand, ElementName=WorkspaceRoot}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{Binding SurfaceTitle}">
                                        <Grid>
                                            <Border x:Name="AvatarBorder"
                                                    Width="44"
                                                    Height="44"
                                                    CornerRadius="22"
                                                    Background="#B8133541"
                                                    BorderBrush="#47667C"
                                                    BorderThickness="1">
                                                <TextBlock Text="{Binding Initial}"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           FontWeight="Bold"
                                                           FontSize="15"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                            <Ellipse Width="10" Height="10"
                                                     Fill="{StaticResource SuccessBrush}"
                                                     Stroke="#071321"
                                                     StrokeThickness="2"
                                                     HorizontalAlignment="Right"
                                                     VerticalAlignment="Bottom"
                                                     Margin="0,0,1,2" />
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <ItemsControl ItemsSource="{Binding Workspace.VisibleSessions}"
                              HorizontalContentAlignment="Stretch"
                              VerticalContentAlignment="Stretch">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="{Binding DataContext.Workspace.LayoutRows, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                         Columns="{Binding DataContext.Workspace.LayoutColumns, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Margin" Value="3" />
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                            <Setter Property="VerticalAlignment" Value="Stretch" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource SessionPaneBorderStyle}" ClipToBounds="True">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="40" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid Background="#E0081728" Margin="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Button Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                HorizontalContentAlignment="Left"
                                                Padding="13,0"
                                                Command="{Binding DataContext.Workspace.SelectSessionCommand, ElementName=WorkspaceRoot}"
                                                CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="9" Height="9" Fill="{StaticResource SuccessBrush}" Margin="0,0,9,0" />
                                                <TextBlock Text="{Binding SurfaceTitle}" FontSize="12" FontWeight="SemiBold"
                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Button>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,5,0">
                                            <Button Content="&#xE8A7;"
                                                    FontFamily="Segoe Fluent Icons"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Width="34"
                                                    Command="{Binding DataContext.Workspace.DetachSessionCommand, ElementName=WorkspaceRoot}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="{loc:Localize Session_DetachTooltip}" />
                                            <Button Content="&#xE711;"
                                                    FontFamily="Segoe Fluent Icons"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Width="34"
                                                    Command="{Binding DataContext.Workspace.CloseSessionCommand, ElementName=WorkspaceRoot}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="{loc:Localize Session_End}" />
                                        </StackPanel>
                                    </Grid>
                                    <Border Grid.Row="1" Background="#01050B">
                                        <hosting:GameSurfacePresenter Attachment="{Binding Attachment}" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Workspace.HasSessions}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="&#xE7FC;" FontFamily="Segoe Fluent Icons" FontSize="34"
                               Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="{loc:Localize Workspace_EmptyTitle}" FontSize="17" FontWeight="SemiBold" Margin="0,12,0,0" />
                    <Button Content="{loc:Localize Accounts_OpenLabel}" Command="{Binding AddAccountCommand}"
                            Style="{StaticResource WorkspaceToolbarButtonStyle}" Margin="0,14,0,0" />
                </StackPanel>
            </Grid>
        </Grid>

        <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                <Ellipse Width="9" Height="9" Fill="{StaticResource SuccessBrush}" Margin="0,0,10,0" />
                <TextBlock Text="{Binding Workspace.FooterStatus}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
