<UserControl x:Class="LegendLauncher.App.Views.Updates.UpdateStatusView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:LegendLauncher.App.Localization"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <Style x:Key="UpdateCompactButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="FontSize" Value="8.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Resources>

    <Grid Visibility="{Binding IsUpdateCardVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Border x:Name="UpdateCard"
                MinHeight="72"
                Padding="11,9"
                Background="#E30A1828"
                BorderBrush="{Binding UpdateStatusBrush}"
                BorderThickness="1"
                CornerRadius="9"
                AutomationProperties.Name="{loc:Localize Update_CardAutomation}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="7" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Ellipse Width="7"
                             Height="7"
                             Fill="{Binding UpdateStatusBrush}"
                             VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding UpdateEyebrowText}"
                               FontSize="8"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" />
                </Grid>

                <TextBlock Grid.Row="1"
                           Margin="0,5,0,0"
                           Text="{Binding UpdateTitleText}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           TextTrimming="CharacterEllipsis" />

                <TextBlock Grid.Row="2"
                           Margin="0,3,0,0"
                           Text="{Binding UpdateDetailText}"
                           FontSize="9"
                           LineHeight="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />

                <ProgressBar Grid.Row="3"
                             Height="3"
                             Margin="0,7,0,0"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding UpdateProgress, Mode=OneWay}"
                             Foreground="{StaticResource AccentBrush}"
                             Visibility="{Binding IsUpdateProgressVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <StackPanel Grid.Row="3"
                            Margin="0,8,0,0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Margin="0,0,6,0"
                            Style="{StaticResource UpdateCompactButtonStyle}"
                            Content="{Binding UpdateViewNotesText}"
                            Command="{Binding ToggleUpdateNotesCommand}"
                            Visibility="{Binding IsUpdateReadyToInstall, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button Style="{StaticResource UpdateCompactButtonStyle}"
                            Content="{Binding UpdateActionText}"
                            Command="{Binding InstallUpdateCommand}"
                            ToolTip="{loc:Localize Update_ActionTooltip}"
                            Visibility="{Binding IsUpdateReadyToInstall, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button Style="{StaticResource UpdateCompactButtonStyle}"
                            Content="{Binding UpdateCheckActionText}"
                            Command="{Binding CheckForUpdatesCommand}"
                            Visibility="{Binding IsUpdateCheckActionVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
            </Grid>
        </Border>

        <Popup PlacementTarget="{Binding ElementName=UpdateCard}"
               Placement="Top"
               VerticalOffset="-8"
               AllowsTransparency="True"
               StaysOpen="False"
               DataContext="{Binding}"
               IsOpen="{Binding IsUpdateNotesOpen, Mode=TwoWay}">
            <Border Width="330"
                    MaxHeight="360"
                    Padding="16"
                    Background="#FA0A1727"
                    BorderBrush="{StaticResource AccentStrongBrush}"
                    BorderThickness="1"
                    CornerRadius="11"
                    AutomationProperties.Name="{loc:Localize Update_NotesAutomation}">
                <Border.Effect>
                    <DropShadowEffect Color="#000000"
                                      BlurRadius="24"
                                      ShadowDepth="8"
                                      Opacity="0.65" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding UpdateEyebrowText}"
                                       FontSize="9"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}" />
                            <TextBlock Margin="0,5,0,0"
                                       Text="{Binding UpdateNotesTitleText}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Width="30"
                                Height="30"
                                Padding="0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding CloseUpdateNotesCommand}"
                                ToolTip="{Binding UpdateCloseNotesText}">
                            <TextBlock Text="&#xE711;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="11" />
                        </Button>
                    </Grid>

                    <ScrollViewer Grid.Row="2"
                                  MaxHeight="190"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <TextBlock Text="{Binding UpdateNotesText}"
                                   FontSize="11"
                                   LineHeight="18"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </ScrollViewer>

                    <Border Grid.Row="4"
                            Padding="10,8"
                            Background="#151F3347"
                            BorderBrush="#36516A"
                            BorderThickness="1"
                            CornerRadius="7">
                        <TextBlock Text="{Binding UpdateSessionWarningText}"
                                   FontSize="9"
                                   LineHeight="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </Border>

                    <StackPanel Grid.Row="6"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Margin="0,0,8,0"
                                Style="{StaticResource UpdateCompactButtonStyle}"
                                Content="{Binding UpdateCloseNotesText}"
                                Command="{Binding CloseUpdateNotesCommand}" />
                        <Button Style="{StaticResource UpdateCompactButtonStyle}"
                                Content="{Binding UpdateActionText}"
                                Command="{Binding InstallUpdateCommand}"
                                ToolTip="{loc:Localize Update_ActionTooltip}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</UserControl>
