<UserControl x:Class="LegendLauncher.App.Views.Donation.DonationPromptView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="clr-namespace:LegendLauncher.App.Localization"
             mc:Ignorable="d"
             d:DesignWidth="1180"
             d:DesignHeight="700"
             Focusable="True"
             KeyboardNavigation.TabNavigation="Cycle"
             AutomationProperties.Name="{loc:Localize Donation_DialogAutomation}">
    <UserControl.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CloseDonationPromptCommand}" />
    </UserControl.InputBindings>

    <Grid Background="#E8020A14">
        <Border MaxWidth="930"
                MinHeight="520"
                Margin="36"
                Padding="34"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#0A1928"
                BorderBrush="#3D6682"
                BorderThickness="1"
                CornerRadius="26">
            <Border.Effect>
                <DropShadowEffect Color="#35E5D8"
                                  BlurRadius="34"
                                  ShadowDepth="0"
                                  Opacity="0.20" />
            </Border.Effect>

            <Grid>
                <Canvas IsHitTestVisible="False"
                        ClipToBounds="True"
                        Opacity="0.24">
                    <Rectangle Canvas.Left="338"
                               Canvas.Top="-160"
                               Width="2"
                               Height="780"
                               Fill="#35E5D8"
                               RenderTransformOrigin="0.5,0.5">
                        <Rectangle.RenderTransform>
                            <RotateTransform Angle="28" />
                        </Rectangle.RenderTransform>
                    </Rectangle>
                    <Rectangle Canvas.Left="360"
                               Canvas.Top="104"
                               Width="16"
                               Height="16"
                               Fill="#35E5D8"
                               RenderTransformOrigin="0.5,0.5">
                        <Rectangle.RenderTransform>
                            <RotateTransform Angle="45" />
                        </Rectangle.RenderTransform>
                    </Rectangle>
                    <Rectangle Canvas.Left="394"
                               Canvas.Top="177"
                               Width="10"
                               Height="10"
                               Fill="#F5B95A"
                               RenderTransformOrigin="0.5,0.5">
                        <Rectangle.RenderTransform>
                            <RotateTransform Angle="45" />
                        </Rectangle.RenderTransform>
                    </Rectangle>
                    <Rectangle Canvas.Left="432"
                               Canvas.Top="248"
                               Width="20"
                               Height="20"
                               Fill="#35E5D8"
                               RenderTransformOrigin="0.5,0.5">
                        <Rectangle.RenderTransform>
                            <RotateTransform Angle="45" />
                        </Rectangle.RenderTransform>
                    </Rectangle>
                </Canvas>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.06*" />
                        <ColumnDefinition Width="38" />
                        <ColumnDefinition Width="0.94*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,4,0,2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <Border Width="34"
                                    Height="34"
                                    Background="#102C45"
                                    BorderBrush="#247CB4"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <Grid>
                                    <TextBlock Margin="-3,-1,0,0"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontFamily="Segoe UI Variable Display, Segoe UI"
                                               FontSize="19"
                                               FontWeight="Bold"
                                               FontStyle="Italic"
                                               Foreground="#003087"
                                               Text="P" />
                                    <TextBlock Margin="2,3,0,0"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontFamily="Segoe UI Variable Display, Segoe UI"
                                               FontSize="19"
                                               FontWeight="Bold"
                                               FontStyle="Italic"
                                               Foreground="#009CDE"
                                               Text="P" />
                                </Grid>
                            </Border>
                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="#35E5D8"
                                           Text="{loc:Localize Donation_Eyebrow}" />
                                <TextBlock Margin="0,2,0,0"
                                           FontSize="9"
                                           FontWeight="SemiBold"
                                           Foreground="#718DA4"
                                           Text="URUS LAUNCHER · PAYPAL" />
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Grid.Row="1"
                                   Margin="0,28,0,0"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="31"
                                   FontWeight="SemiBold"
                                   LineHeight="36"
                                   Text="{loc:Localize Donation_Title}"
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="2"
                                   Margin="0,15,10,0"
                                   FontSize="14"
                                   Foreground="#B7CADB"
                                   LineHeight="21"
                                   Text="{loc:Localize Donation_Body}"
                                   TextWrapping="Wrap" />

                        <Border Grid.Row="3"
                                Margin="0,22,8,0"
                                Padding="15,13"
                                Background="#142133"
                                BorderBrush="#7A5A2A"
                                BorderThickness="1"
                                CornerRadius="13">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Top"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="17"
                                           Foreground="#F5B95A"
                                           Text="&#xE734;" />
                                <TextBlock Grid.Column="2"
                                           FontSize="12.5"
                                           Foreground="#E7D7B6"
                                           LineHeight="19"
                                           Text="{loc:Localize Donation_Joke}"
                                           TextWrapping="Wrap" />
                            </Grid>
                        </Border>

                        <Button x:Name="ClosePromptButton"
                                Grid.Row="5"
                                Width="132"
                                Height="40"
                                Margin="0,27,0,0"
                                Padding="15,8"
                                HorizontalAlignment="Left"
                                Background="#0B1826"
                                BorderBrush="#3A627B"
                                BorderThickness="1"
                                Command="{Binding CloseDonationPromptCommand}"
                                Content="{loc:Localize Donation_NotNow}"
                                FontSize="13"
                                Foreground="#C8D8E6"
                                Style="{StaticResource SecondaryButtonStyle}"
                                ToolTip="{loc:Localize Donation_CloseTooltip}"
                                AutomationProperties.Name="{loc:Localize Donation_CloseAutomation}" />
                    </Grid>

                    <Grid Grid.Column="2" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Padding="14"
                                HorizontalAlignment="Center"
                                Background="White"
                                CornerRadius="20">
                            <Image Width="300"
                                   Height="300"
                                   Source="/UrusLauncher.App;component/Assets/paypal-donation-qr.jpeg"
                                   Stretch="Uniform"
                                   SnapsToDevicePixels="True"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   AutomationProperties.Name="{loc:Localize Donation_QrAutomation}" />
                        </Border>

                        <Border Grid.Row="2"
                                Padding="13,10"
                                Background="#0D2234"
                                BorderBrush="#1D5370"
                                BorderThickness="1"
                                CornerRadius="12">
                            <StackPanel>
                                <TextBlock HorizontalAlignment="Center"
                                           FontSize="10.5"
                                           FontWeight="Bold"
                                           Foreground="#35E5D8"
                                           Text="{loc:Localize Donation_ScanLabel}" />
                                <TextBlock Margin="6,5,6,0"
                                           HorizontalAlignment="Center"
                                           FontSize="11"
                                           Foreground="#9FB7C9"
                                           LineHeight="16"
                                           Text="{loc:Localize Donation_ScanHint}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Row="3"
                                    Margin="0,12,0,0"
                                    HorizontalAlignment="Center"
                                    Orientation="Horizontal">
                            <TextBlock Margin="0,0,7,0"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="11"
                                       Foreground="#718DA4"
                                       Text="&#xE72E;" />
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="10"
                                       Foreground="#718DA4"
                                       Text="{loc:Localize Donation_QrIntegrity}" />
                        </StackPanel>

                        <Border x:Name="PixDonationPanel"
                                Grid.Row="4"
                                Margin="0,14,0,0"
                                Padding="14,12"
                                Background="#0D2630"
                                BorderBrush="#247C78"
                                BorderThickness="1"
                                CornerRadius="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock VerticalAlignment="Center"
                                               FontFamily="Segoe Fluent Icons"
                                               FontSize="13"
                                               Foreground="#58D68D"
                                               Text="&#xE8C7;" />
                                    <TextBlock Margin="8,0,0,0"
                                               VerticalAlignment="Center"
                                               FontSize="10.5"
                                               FontWeight="Bold"
                                               Foreground="#58D68D"
                                               Text="{loc:Localize Donation_PixTitle}" />
                                    <Border Width="1"
                                            Height="12"
                                            Margin="9,0"
                                            VerticalAlignment="Center"
                                            Background="#386B72" />
                                    <TextBlock VerticalAlignment="Center"
                                               FontSize="9.5"
                                               FontWeight="SemiBold"
                                               Foreground="#91AEBB"
                                               Text="{loc:Localize Donation_PixDocumentLabel}" />
                                </StackPanel>

                                <TextBox x:Name="PixCnpjText"
                                         Grid.Row="1"
                                         Margin="17,5,0,0"
                                         Padding="4,2"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         CaretBrush="#8DE8D9"
                                         FontFamily="Cascadia Mono, Consolas"
                                         FontSize="13"
                                         FontWeight="SemiBold"
                                         Foreground="#E2F4F0"
                                         IsReadOnly="True"
                                         Text="57.646.942/0001-69"
                                         ToolTip="{loc:Localize Donation_PixKeyTooltip}"
                                         AutomationProperties.Name="{loc:Localize Donation_PixKeyAutomation}" />

                                <Button x:Name="CopyPixButton"
                                        Grid.RowSpan="2"
                                        Grid.Column="2"
                                        Height="34"
                                        MinWidth="92"
                                        Padding="12,0"
                                        VerticalAlignment="Center"
                                        Background="#123A40"
                                        BorderBrush="#35A99E"
                                        BorderThickness="1"
                                        Click="CopyPixButton_OnClick"
                                        Content="{loc:Localize Donation_PixCopy}"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="#8DE8D9"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        ToolTip="{loc:Localize Donation_PixCopyTooltip}"
                                        AutomationProperties.HelpText="{loc:Localize Donation_PixCopyHelp}"
                                        AutomationProperties.Name="{loc:Localize Donation_PixCopyAutomation}" />

                                <TextBlock x:Name="PixCopySuccessText"
                                           Grid.Row="2"
                                           Grid.ColumnSpan="3"
                                           Margin="21,8,0,0"
                                           FontSize="10"
                                           Foreground="#58D68D"
                                           Text="{loc:Localize Donation_PixCopied}"
                                           TextWrapping="Wrap"
                                           Visibility="Collapsed"
                                           AutomationProperties.LiveSetting="Polite"
                                           AutomationProperties.Name="{loc:Localize Donation_PixCopiedAutomation}" />
                                <TextBlock x:Name="PixCopyFailureText"
                                           Grid.Row="2"
                                           Grid.ColumnSpan="3"
                                           Margin="21,8,0,0"
                                           FontSize="10"
                                           Foreground="#FF8290"
                                           Text="{loc:Localize Donation_PixCopyFailed}"
                                           TextWrapping="Wrap"
                                           Visibility="Collapsed"
                                           AutomationProperties.LiveSetting="Assertive"
                                           AutomationProperties.Name="{loc:Localize Donation_PixCopyFailedAutomation}" />
                            </Grid>
                        </Border>
                    </Grid>

                    <Button Width="38"
                            Height="38"
                            Margin="0,-17,-17,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Grid.Column="2"
                            Background="#0D1D2C"
                            BorderBrush="#33566D"
                            BorderThickness="1"
                            Command="{Binding CloseDonationPromptCommand}"
                            Content="&#xE8BB;"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="14"
                            Foreground="#AFC3D3"
                            Style="{StaticResource SecondaryButtonStyle}"
                            ToolTip="{loc:Localize Donation_CloseTooltip}"
                            AutomationProperties.Name="{loc:Localize Donation_CloseAutomation}" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
