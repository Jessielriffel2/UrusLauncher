<Window x:Class="LegendLauncher.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:game="clr-namespace:LegendLauncher.App.Views.Game"
        xmlns:donation="clr-namespace:LegendLauncher.App.Views.Donation"
        xmlns:updates="clr-namespace:LegendLauncher.App.Views.Updates"
        xmlns:loc="clr-namespace:LegendLauncher.App.Localization"
        mc:Ignorable="d"
        Title="{loc:Localize App_WindowTitle}"
        Width="1420"
        Height="820"
        MinWidth="1180"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#01050C"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            ResizeBorderThickness="6"
                            CornerRadius="9"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border CornerRadius="9" BorderBrush="#33465C" BorderThickness="1" ClipToBounds="True">
        <Grid Background="{StaticResource WindowBackgroundBrush}" ClipToBounds="True">
            <Ellipse Width="520" Height="420" HorizontalAlignment="Left" VerticalAlignment="Top"
                     Margin="-180,-250,0,0" IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#3634DCD0" Offset="0" />
                        <GradientStop Color="#0016303B" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Width="380" Height="300" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                     Margin="0,0,-210,-190" Fill="#241C365D" IsHitTestVisible="False" />

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid x:Name="LauncherHeader"
                      Grid.Row="0"
                      Height="96"
                      Visibility="{Binding IsLauncherVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center"
                                Margin="46,13,0,0">
                        <Image Width="52" Height="52" Source="Assets/Branding/urus-logo.png"
                               Stretch="Uniform" IsHitTestVisible="False">
                            <Image.Effect>
                                <DropShadowEffect Color="#35E5D8" BlurRadius="14" ShadowDepth="0" Opacity="0.72" />
                            </Image.Effect>
                        </Image>
                        <Border Width="1" Height="49" Margin="14,0,14,0" Background="#477188" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="U R U S  L A U N C H E R" FontSize="21" FontWeight="Bold"
                                       FontFamily="Segoe UI Variable Display, Segoe UI" />
                            <TextBlock Text="{loc:Localize Brand_Subtitle}" Margin="0,3,0,0"
                                        FontSize="9.5" FontWeight="SemiBold" Foreground="#8DA3B9" />
                        </StackPanel>
                        <Button x:Name="DonationHeaderButton"
                                Width="44"
                                Height="38"
                                Margin="16,0,0,0"
                                Padding="0"
                                Background="#102C45"
                                BorderBrush="#247CB4"
                                BorderThickness="1"
                                Command="{Binding OpenDonationPromptCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                ToolTip="{loc:Localize Donation_HeaderTooltip}"
                                AutomationProperties.Name="{loc:Localize Donation_HeaderAutomation}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Grid Width="24" Height="25">
                                <TextBlock Margin="-4,-2,0,0"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe UI Variable Display, Segoe UI"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           FontStyle="Italic"
                                           Foreground="#003087"
                                           Text="P" />
                                <TextBlock Margin="2,3,0,0"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe UI Variable Display, Segoe UI"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           FontStyle="Italic"
                                           Foreground="#009CDE"
                                           Text="P" />
                            </Grid>
                        </Button>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Margin="0,8,150,0">
                        <ComboBox x:Name="LanguageSelector"
                                  Width="160"
                                  Margin="0,0,10,0"
                                  Style="{StaticResource LanguageComboStyle}"
                                  ItemsSource="{Binding Languages}"
                                  SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayName"
                                  PreviewMouseLeftButtonDown="ComboBoxSelector_OnPreviewMouseLeftButtonDown"
                                  PreviewKeyDown="ComboBoxSelector_OnPreviewKeyDown"
                                  ToolTip="{loc:Localize Language_Select}"
                                  AutomationProperties.Name="{loc:Localize Language_SelectAutomation}"
                                  shell:WindowChrome.IsHitTestVisibleInChrome="True" />
                        <Border Style="{StaticResource PillBorderStyle}" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="11" Height="11" Fill="{Binding CatalogStatusBrush}" Margin="0,0,9,0" />
                                <TextBlock Text="{Binding CatalogStatus}" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource PillBorderStyle}">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="14" Height="14" CornerRadius="7" Background="{Binding RuntimeStatusBrush}" Margin="0,0,8,0">
                                    <TextBlock Text="&#xE73E;" FontFamily="Segoe Fluent Icons" FontSize="8"
                                               Foreground="#0A1420" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="{Binding RuntimeStatusShort}" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                </Grid>

                <Grid Grid.Row="1" Margin="20,0,20,30"
                      Visibility="{Binding IsLauncherVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="268" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" MinWidth="490" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="354" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="0" ClipToBounds="True">
                        <Grid ClipToBounds="True">
                            <Image Source="Assets/castle-background.png" Stretch="UniformToFill" Opacity="1"
                                   HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False"
                                   RenderTransformOrigin="0.5,0.5">
                                <Image.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="1.22" ScaleY="1.22" />
                                        <TranslateTransform X="42" Y="-105" />
                                    </TransformGroup>
                                </Image.RenderTransform>
                            </Image>
                            <Rectangle IsHitTestVisible="False">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#FA0D1D2D" Offset="0" />
                                        <GradientStop Color="#D80C1A2A" Offset="0.18" />
                                        <GradientStop Color="#40101C2B" Offset="0.47" />
                                        <GradientStop Color="#6507121F" Offset="1" />
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>

                            <Grid Margin="18,25,18,15">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="24" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="100" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{loc:Localize Accounts_Eyebrow}" Style="{StaticResource EyebrowTextStyle}" />
                                        <TextBlock Text="{loc:Localize Profiles_Title}" FontSize="17" FontWeight="SemiBold" Margin="0,8,0,0" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="&#xE710;" Style="{StaticResource IconButtonStyle}"
                                            Width="44" Height="44" Command="{Binding NewProfileCommand}"
                                            ToolTip="{loc:Localize Profiles_Create}" AutomationProperties.Name="{loc:Localize Profiles_Create}" />
                                </Grid>

                                <ListBox x:Name="ProfileList" Grid.Row="2" ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
                                         ItemContainerStyle="{StaticResource ProfileListItemStyle}"
                                         Background="Transparent" BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Hidden">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="40" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="22" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="40" Height="40" CornerRadius="20"
                                                        Background="#173C48" BorderBrush="{StaticResource AccentStrongBrush}" BorderThickness="1">
                                                    <TextBlock Text="&#xE77B;" FontFamily="Segoe Fluent Icons" FontSize="21"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <TextBlock Grid.Column="2" Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold"
                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                <Button Grid.Column="3" Style="{StaticResource ProfileOverflowButtonStyle}"
                                                        Click="ProfileMenuButton_OnClick" ToolTip="{loc:Localize Profiles_RecentServers}"
                                                        AutomationProperties.Name="{loc:Localize Profiles_OpenRecentServers}">
                                                    <TextBlock Text="⋮" FontFamily="Segoe UI Symbol" FontSize="19"
                                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Button Grid.Row="2" Height="62" VerticalAlignment="Top" Padding="0"
                                        Command="{Binding NewProfileCommand}" AutomationProperties.Name="{loc:Localize Profiles_CreateMyProfile}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="DraftProfileBorder" Background="#B51A3C46"
                                                                BorderBrush="{StaticResource AccentStrongBrush}" BorderThickness="1"
                                                                CornerRadius="10" Padding="11,8">
                                                            <ContentPresenter />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="DraftProfileBorder" Property="Background" Value="#D21D4852" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasItems, ElementName=ProfileList}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="22" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="40" Height="40" CornerRadius="20"
                                                Background="#173C48" BorderBrush="{StaticResource AccentStrongBrush}" BorderThickness="1">
                                            <TextBlock Text="&#xE77B;" FontFamily="Segoe Fluent Icons" FontSize="21"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{loc:Localize Profiles_DefaultName}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="3" Text="⋮" FontFamily="Segoe UI Symbol" FontSize="19"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Grid>
                                </Button>

                                <updates:UpdateStatusView Grid.Row="4" />

                                <Border Grid.Row="6" Background="#C9081626" BorderBrush="{StaticResource BorderStrongBrush}"
                                        BorderThickness="1" CornerRadius="10" Padding="13">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="22" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#xEA18;" FontFamily="Segoe Fluent Icons" FontSize="17"
                                                   Foreground="#D5E5F3" VerticalAlignment="Top" Margin="0,1,0,0" />
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="{loc:Localize Security_ProtectedDataTitle}" FontSize="12" FontWeight="SemiBold" />
                                            <TextBlock Text="{loc:Localize Security_ProtectedDataDescription}"
                                                       Style="{StaticResource CaptionTextStyle}" Margin="0,5,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Padding="22,14,22,22">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="14" />
                                <RowDefinition Height="46" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="28" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{loc:Localize Servers_Eyebrow}" Style="{StaticResource EyebrowTextStyle}" />
                                    <TextBlock Text="{loc:Localize Servers_ChooseWorld}" Style="{StaticResource SectionTitleTextStyle}" Margin="0,7,0,0" />
                                    <TextBlock Text="{loc:Localize Servers_CatalogDescription}"
                                               Style="{StaticResource BodyTextStyle}" Margin="0,2,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                                    <ComboBox Width="210" Style="{StaticResource PlatformComboStyle}"
                                              ItemsSource="{Binding Platforms}" SelectedItem="{Binding SelectedPlatform}"
                                              IsTextSearchEnabled="True" TextSearch.TextPath="DisplayName"
                                              PreviewMouseLeftButtonDown="ComboBoxSelector_OnPreviewMouseLeftButtonDown"
                                              PreviewKeyDown="ComboBoxSelector_OnPreviewKeyDown"
                                              AutomationProperties.Name="{loc:Localize Platforms_SelectVersionAutomation}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <Button Content="&#xE72C;" Style="{StaticResource IconButtonStyle}" Margin="10,0,0,0"
                                            Command="{Binding RefreshServersCommand}" ToolTip="{loc:Localize Servers_Refresh}"
                                            AutomationProperties.Name="{loc:Localize Servers_Refresh}" />
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="96" />
                                </Grid.ColumnDefinitions>
                                <Grid>
                                    <TextBox x:Name="ServerSearchInput" Style="{StaticResource SearchInputStyle}"
                                             Padding="46,0,14,0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                             AutomationProperties.Name="{loc:Localize Servers_SearchAutomation}" />
                                    <TextBlock Text="&#xE721;" FontFamily="Segoe Fluent Icons" FontSize="18"
                                               Foreground="{StaticResource TextMutedBrush}" Margin="17,0,0,0"
                                               HorizontalAlignment="Left" VerticalAlignment="Center" IsHitTestVisible="False" />
                                    <TextBlock Text="{loc:Localize Servers_SearchPlaceholder}" Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="12" Margin="47,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text.Length, ElementName=ServerSearchInput}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <TextBlock Grid.Column="1" Text="{Binding ServerCountLabel}" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center" />
                            </Grid>

                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ProgressBar Width="28" Height="4" IsIndeterminate="True" VerticalAlignment="Center"
                                             Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Ellipse Grid.Column="0" Width="10" Height="10" Fill="{Binding CatalogStatusBrush}" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Grid.Column="2" Text="{Binding StatusMessage}" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Grid Grid.Row="6">
                                <ListBox ItemsSource="{Binding VisibleServers}" SelectedItem="{Binding SelectedServer}"
                                         ItemContainerStyle="{StaticResource ServerListItemStyle}"
                                         ItemTemplate="{StaticResource ServerRowTemplate}"
                                         Background="Transparent" BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                         ScrollViewer.CanContentScroll="True"
                                         VirtualizingPanel.IsVirtualizing="True"
                                         VirtualizingPanel.VirtualizationMode="Recycling">
                                </ListBox>

                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Visibility="{Binding ShowEmptyState, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="&#xE721;" FontFamily="Segoe Fluent Icons" FontSize="30"
                                               Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" />
                                    <TextBlock Text="{loc:Localize Servers_EmptyTitle}" FontWeight="SemiBold" Margin="0,12,0,0" />
                                    <TextBlock Text="{loc:Localize Servers_EmptyDescription}"
                                               Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="4" Style="{StaticResource CardBorderStyle}" Padding="22,14,22,19">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="72" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="54" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <ScrollViewer x:Name="SessionSetupScrollViewer"
                                          Grid.Row="0"
                                          MinHeight="0"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto"
                                          CanContentScroll="False">
                                <Grid Margin="0,0,6,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="14" />
                                        <RowDefinition Height="74" />
                                        <RowDefinition Height="17" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="15" />
                                        <RowDefinition Height="18" />
                                        <RowDefinition Height="17" />
                                        <RowDefinition Height="38" />
                                    </Grid.RowDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="{loc:Localize Session_Eyebrow}" Style="{StaticResource EyebrowTextStyle}" />
                                        <TextBlock Text="{loc:Localize Session_ReadyTitle}" Style="{StaticResource SectionTitleTextStyle}" Margin="0,7,0,0" />
                                        <TextBlock Text="{loc:Localize Session_ReadyDescription}"
                                                   Style="{StaticResource BodyTextStyle}" Margin="0,2,0,0" />
                                    </StackPanel>

                            <Border Grid.Row="2" BorderBrush="#237186" BorderThickness="1" CornerRadius="13" ClipToBounds="True">
                                <Grid ClipToBounds="True">
                                    <Image Source="Assets/selected-server-castle-banner.png" Stretch="UniformToFill"
                                           Opacity="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                        <Image.RenderTransform>
                                            <TranslateTransform X="-80" />
                                        </Image.RenderTransform>
                                    </Image>
                                    <Rectangle>
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#F40D3441" Offset="0" />
                                                <GradientStop Color="#650D2C38" Offset="0.55" />
                                                <GradientStop Color="#000A2732" Offset="1" />
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                    <Grid Margin="17,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{loc:Localize Session_SelectedServer}" FontSize="9" FontWeight="Bold"
                                                       Foreground="#78AFC4" />
                                            <TextBlock Text="{Binding SelectedServerDisplayName}"
                                                       FontSize="16" FontWeight="SemiBold" Margin="0,6,0,0"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <Border Grid.Column="1" Background="#B20E6B70" CornerRadius="8" Padding="12,9" Margin="10,0,0,0"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding SelectedServer.Code, TargetNullValue=—}"
                                                       Foreground="#E8FFFC" FontSize="14" FontWeight="Bold" />
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Grid.Row="4" Grid.RowSpan="5"
                                    Background="#A4081728"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="16,14"
                                    Visibility="{Binding IsProfileReadyVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="46" Height="46" CornerRadius="23"
                                                Background="#B51A3C46"
                                                BorderBrush="{StaticResource AccentStrongBrush}"
                                                BorderThickness="1">
                                            <TextBlock Text="{Binding SelectedProfile.Initial, TargetNullValue=?}"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontSize="17" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding SelectedProfileSummary}"
                                                       FontSize="16" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding SelectedPlatform.DisplayName}"
                                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                                       Margin="0,3,0,0" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Grid>
                                    <Border Background="#80112A34" CornerRadius="7" Padding="10,8" Margin="0,13,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE73E;" FontFamily="Segoe Fluent Icons"
                                                       Foreground="{StaticResource SuccessBrush}" FontSize="12" Margin="0,0,8,0" />
                                            <TextBlock Text="{Binding CredentialStatusText}" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                        </StackPanel>
                                    </Border>
                                    <Button Content="{loc:Localize Accounts_Edit}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding EditProfileCommand}"
                                            Height="36" Margin="0,12,0,0" />
                                </StackPanel>
                            </Border>

                            <StackPanel Grid.Row="4"
                                        Visibility="{Binding IsProfileEditorVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="{loc:Localize Profiles_NameLabel}" Style="{StaticResource FieldLabelStyle}" />
                                <Grid>
                                    <TextBox x:Name="ProfileNameInput" Style="{StaticResource InputStyle}"
                                             Text="{Binding ProfileLabel, UpdateSourceTrigger=PropertyChanged}"
                                             AutomationProperties.Name="{loc:Localize Profiles_NameLabel}" />
                                    <TextBlock Text="{loc:Localize Profiles_NamePlaceholder}" Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="12" Margin="14,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text.Length, ElementName=ProfileNameInput}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <TextBlock Text="{loc:Localize Profiles_LoginLabel}" Style="{StaticResource FieldLabelStyle}" Margin="0,14,0,7" />
                                <Grid>
                                    <TextBox x:Name="LoginInput" Style="{StaticResource InputStyle}"
                                             Text="{Binding LoginHint, UpdateSourceTrigger=PropertyChanged}"
                                             AutomationProperties.Name="{loc:Localize Profiles_LoginLabel}" />
                                    <TextBlock Text="{loc:Localize Profiles_LoginPlaceholder}" Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="12" Margin="14,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text.Length, ElementName=LoginInput}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <TextBlock Text="{loc:Localize Profiles_PasswordLabel}" Style="{StaticResource FieldLabelStyle}" Margin="0,14,0,7" />
                                <Grid>
                                    <PasswordBox x:Name="PasswordInput" Style="{StaticResource PasswordInputStyle}"
                                                 Padding="13,0,42,0" PasswordChanged="PasswordInput_OnPasswordChanged"
                                                 AutomationProperties.Name="{loc:Localize Profiles_PasswordLabel}" />
                                    <TextBlock x:Name="PasswordPlaceholder" Text="{Binding PasswordPlaceholderText}"
                                               FontSize="12" Margin="14,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasSavedCredential}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="&#xE890;" FontFamily="Segoe Fluent Icons" FontSize="15"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,14,0"
                                               HorizontalAlignment="Right" VerticalAlignment="Center" IsHitTestVisible="False" />
                                </Grid>
                            </StackPanel>

                            <CheckBox Grid.Row="6" Content="{loc:Localize Credentials_RememberPassword}"
                                      IsChecked="{Binding RememberPassword}" Style="{StaticResource ModernCheckBoxStyle}"
                                      VerticalAlignment="Center"
                                      Visibility="{Binding IsProfileEditorVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <Grid Grid.Row="8"
                                  Visibility="{Binding IsProfileEditorVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Content="{loc:Localize Profiles_Save}" Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding SaveProfileCommand}" />
                                <Button Grid.Column="2" Content="{loc:Localize Common_Cancel}" Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding CancelProfileEditCommand}" />
                            </Grid>

                                </Grid>
                            </ScrollViewer>

                            <Border Grid.Row="1"
                                    Height="1"
                                    VerticalAlignment="Center"
                                    Background="{StaticResource BorderBrush}" />

                            <Border x:Name="PinnedRuntimeStatus"
                                    Grid.Row="2" Background="#B1081728" BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="10" Padding="13,9">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="9" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="17" Height="17" CornerRadius="9" Background="{Binding RuntimeStatusBrush}"
                                            VerticalAlignment="Top">
                                        <TextBlock Text="&#xE73E;" FontFamily="Segoe Fluent Icons" FontSize="9"
                                                   Foreground="#05211A" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{Binding RuntimeStatusShort}" FontSize="12" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding RuntimeStatusDetail}" FontSize="10" LineHeight="14.5"
                                                   Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Button x:Name="PinnedPrimaryAction"
                                    Grid.Row="4" Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding PlayCommand}" IsEnabled="{Binding CanStartGame}"
                                    Click="PlayButton_OnClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE7FC;" FontFamily="Segoe Fluent Icons" FontSize="18"
                                               Margin="0,0,12,0" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding PrimaryActionLabel}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <TextBlock x:Name="PinnedSessionCaption"
                                       Grid.Row="6"
                                       Text="{loc:Localize Session_IsolationCaption}"
                                       Style="{StaticResource CaptionTextStyle}" TextAlignment="Center"
                                       HorizontalAlignment="Center" Margin="8,0" />
                        </Grid>
                    </Border>
                </Grid>
                <game:GameWorkspaceView Grid.Row="1"
                                        Visibility="{Binding IsWorkspaceVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <StackPanel x:Name="MainWindowCaptionButtons"
                            Grid.Row="0"
                            Grid.RowSpan="2"
                            Panel.ZIndex="100"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top">
                    <Button Content="&#xE921;"
                            Style="{StaticResource WindowCaptionButtonStyle}"
                            Height="44"
                            Click="MinimizeButton_OnClick"
                            AutomationProperties.Name="{loc:Localize Window_Minimize}" />
                    <Button x:Name="MaximizeButton"
                            Content="&#xE922;"
                            Style="{StaticResource WindowCaptionButtonStyle}"
                            Height="44"
                            Click="MaximizeButton_OnClick"
                            AutomationProperties.Name="{loc:Localize Window_MaximizeRestore}" />
                    <Button Content="&#xE8BB;"
                            Style="{StaticResource CloseCaptionButtonStyle}"
                            Height="44"
                            Click="CloseButton_OnClick"
                            AutomationProperties.Name="{loc:Localize Window_Close}" />
                </StackPanel>
            </Grid>

            <donation:DonationPromptView x:Name="DonationPromptOverlay"
                                         Panel.ZIndex="500"
                                         Visibility="{Binding IsDonationPromptVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </Grid>
    </Border>
</Window>
