<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="BackgroundColor">#030B18</Color>
    <Color x:Key="SurfaceColor">#0B1828</Color>
    <Color x:Key="SurfaceRaisedColor">#102136</Color>
    <Color x:Key="SurfaceSoftColor">#091525</Color>
    <Color x:Key="InputColor">#081525</Color>
    <Color x:Key="BorderColor">#24394F</Color>
    <Color x:Key="BorderStrongColor">#36516A</Color>
    <Color x:Key="TextPrimaryColor">#F3F7FC</Color>
    <Color x:Key="TextSecondaryColor">#A9B7CA</Color>
    <Color x:Key="TextMutedColor">#8294AA</Color>
    <Color x:Key="AccentColor">#35E5D8</Color>
    <Color x:Key="AccentStrongColor">#20C9C3</Color>
    <Color x:Key="AccentSoftColor">#153D45</Color>
    <Color x:Key="SuccessColor">#3DD49A</Color>
    <Color x:Key="WarningColor">#E9B95E</Color>
    <Color x:Key="DangerColor">#FF6276</Color>

    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="{StaticResource SurfaceRaisedColor}" />
    <SolidColorBrush x:Key="SurfaceSoftBrush" Color="{StaticResource SurfaceSoftColor}" />
    <SolidColorBrush x:Key="InputBrush" Color="{StaticResource InputColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrongColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentStrongBrush" Color="{StaticResource AccentStrongColor}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoftColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="WarningSoftBrush" Color="#20E9B95E" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />

    <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#061422" Offset="0" />
        <GradientStop Color="#020A17" Offset="0.42" />
        <GradientStop Color="#05101F" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="PanelGradientBrush" StartPoint="0,0" EndPoint="0.85,1">
        <GradientStop Color="#0E1D2E" Offset="0" />
        <GradientStop Color="#091625" Offset="0.62" />
        <GradientStop Color="#071321" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SelectedRowGradientBrush" StartPoint="0,0" EndPoint="1,0.4">
        <GradientStop Color="#163B43" Offset="0" />
        <GradientStop Color="#102B39" Offset="0.58" />
        <GradientStop Color="#0A2234" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="HeroGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#123440" Offset="0" />
        <GradientStop Color="#0B2433" Offset="0.55" />
        <GradientStop Color="#0A2932" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#31D8D0" Offset="0" />
        <GradientStop Color="#118F88" Offset="1" />
    </LinearGradientBrush>
</ResourceDictionary>
