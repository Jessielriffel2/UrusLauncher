<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework">
    <Style x:Key="WindowCaptionButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="46" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="CaptionButtonBorder" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CaptionButtonBorder" Property="Background" Value="#233247" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="CaptionButtonBorder" Property="Opacity" Value="0.72" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CloseCaptionButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource WindowCaptionButtonStyle}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#C42B3A" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <DataTemplate x:Key="ServerRowTemplate">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="78" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="24" />
            </Grid.ColumnDefinitions>
            <Border Width="66"
                    Height="39"
                    CornerRadius="8"
                    Background="#B00B2634"
                    BorderBrush="#1D3B4F"
                    BorderThickness="1"
                    HorizontalAlignment="Left">
                <TextBlock Text="{Binding Code}"
                           FontWeight="Bold"
                           FontSize="12"
                           Foreground="{StaticResource AccentBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{Binding Name}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding AvailabilityLabel}"
                           FontSize="10"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,2,0,0" />
            </StackPanel>
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        Margin="8,0,2,0"
                        VerticalAlignment="Center">
                <Border ToolTip="{Binding RecommendedBadgeToolTip}" Margin="0,0,5,0">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource RecommendedBadgeStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowRecommendedBadge}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE735;"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="10"
                                   Foreground="{StaticResource WarningBrush}"
                                   Margin="0,0,6,0" />
                        <TextBlock Text="{Binding RecommendedBadgeText}"
                                   FontSize="9"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource WarningBrush}" />
                    </StackPanel>
                </Border>
                <Border ToolTip="{Binding LatestBadgeToolTip}">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource LatestBadgeStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowLatestBadge}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✦"
                                   FontSize="10"
                                   Foreground="{StaticResource AccentBrush}"
                                   Margin="0,0,6,0" />
                        <TextBlock Text="{Binding LatestBadgeText}"
                                   FontSize="9"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}" />
                    </StackPanel>
                </Border>
            </StackPanel>
            <TextBlock Grid.Column="3"
                       Text="&#xE76C;"
                       FontFamily="Segoe Fluent Icons"
                       FontSize="12"
                       Foreground="{StaticResource TextMutedBrush}"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center" />
        </Grid>
    </DataTemplate>

    <Style x:Key="ServerListItemStyle" TargetType="ListBoxItem">
        <Setter Property="Height" Value="55" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,0,6" />
        <Setter Property="IsEnabled" Value="{Binding CanLaunch}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid x:Name="SectionDivider"
                              Height="24"
                              Margin="0,0,0,6"
                              Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Height="1"
                                    Background="#27475C"
                                    VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding SectionLabelText}"
                                       Margin="12,0"
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center" />
                            <Border Grid.Column="2"
                                    Height="1"
                                    Background="#27475C"
                                    VerticalAlignment="Center" />
                        </Grid>
                        <Border x:Name="RowBorder"
                                Grid.Row="1"
                                Background="#B50B192A"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="9"
                                Padding="11,7">
                            <ContentPresenter />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding ShowSectionDivider}" Value="True">
                            <Setter Property="Height" Value="85" />
                            <Setter TargetName="SectionDivider" Property="Visibility" Value="Visible" />
                        </DataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="RowBorder" Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
                            <Setter TargetName="RowBorder" Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="RowBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="RowBorder" Property="BorderThickness" Value="1.4" />
                            <Setter TargetName="RowBorder" Property="Background" Value="{StaticResource SelectedRowGradientBrush}" />
                            <Setter TargetName="RowBorder" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#35E5D8" BlurRadius="10" ShadowDepth="0" Opacity="0.28" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="RowBorder" Property="BorderBrush" Value="#B7FFF8" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="RowBorder" Property="Opacity" Value="0.44" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ProfileListItemStyle" TargetType="ListBoxItem">
        <Setter Property="Height" Value="62" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="ProfileBorder"
                            Background="#74122636"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="11,8">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ProfileBorder" Property="Background" Value="#B8173142" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ProfileBorder" Property="Background" Value="#B51A3C46" />
                            <Setter TargetName="ProfileBorder" Property="BorderBrush" Value="{StaticResource AccentStrongBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="ProfileBorder" Property="BorderBrush" Value="#B7FFF8" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
